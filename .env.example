# ═══════════════════════════════════════════
#  VPNBZK — Production Environment
# ═══════════════════════════════════════════

# ── Домен и SSL ──
DOMAIN=vpn.example.com
EMAIL=admin@example.com

# ── Секреты приложения ──
SECRET_KEY=change-me-to-random-string-64-chars

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=yourbotname
WEBAPP_URL=https://vpn.example.com

# ── Marzban API (внутренняя сеть Docker) ──
MARZBAN_BASE_URL=https://marzban:8000
MARZBAN_ADMIN_USER=admin
MARZBAN_ADMIN_PASS=change-me-strong-password

# ── Marzban Panel ──
SUDO_USERNAME=admin
SUDO_PASSWORD=change-me-strong-password

# ── Доступ ──
# Внешние IP для доступа к /admin, /marzban/, /api/ (через запятую)
MARZBAN_WHITELIST_IPS=1.2.3.4,5.6.7.8
# Telegram ID суперадмина (авто-создаётся при старте)
SUPERADMIN_TELEGRAM_ID=123456789

# ── Xray (Marzban) ──
# Порт для VLESS/VMess fallback (должен совпадать с inbound в Marzban)
XRAY_FALLBACK_PORT=8443

# ── REALITY (лучшая маскировка, не нужен сертификат) ──
# Внешний порт для REALITY (клиенты подключаются сюда)
REALITY_PORT=2053
# Сайт-маскировка (TLS fingerprint будет как у этого сайта)
REALITY_DEST=www.google.com:443
REALITY_SERVER_NAMES=www.google.com,google.com
# Ключи REALITY (сгенерируйте: docker exec vpnbzk-marzban xray x25519)
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=

# ── WARP (опционально: исходящий трафик через Cloudflare) ──
# Включить: запустите scripts/05-setup-warp.sh
WARP_PRIVATE_KEY=
WARP_RESERVED=0,0,0
